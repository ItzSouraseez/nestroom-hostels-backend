# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/nestroom?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_REFRESH_EXPIRES_IN=30d

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
META_WHATSAPP_TOKEN=your_meta_whatsapp_bearer_token
META_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
META_WHATSAPP_API_VERSION=v19.0
META_OTP_TEMPLATE_NAME=otp
META_TEMPLATE_LANGUAGE_CODE=en

# ─── SMTP (Email) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=nestRoom <noreply@nestroom.app>

# ─── Encryption (AES-256 for bank/ID fields) ─────────────────────────────────
# Must be exactly 32 characters (256-bit)
ENCRYPTION_SECRET=your_32_char_secret_key_here_!!!
